---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden pt-16">
    <!-- Parallax background blobs -->
    <div class="absolute inset-0 parallax-slow">
      <div class="absolute top-[15%] left-[10%] w-80 h-80 bg-gradient-to-br from-pink-200/40 to-rose-100/30 rounded-full blur-[100px] animate-blob"></div>
      <div class="absolute bottom-[20%] right-[10%] w-96 h-96 bg-gradient-to-tl from-accent/15 to-pink-100/20 rounded-full blur-[120px] animate-blob" style="animation-delay: -7s;"></div>
      <div class="absolute top-[50%] left-[50%] w-64 h-64 bg-gradient-to-r from-rose-100/25 to-pink-200/20 rounded-full blur-[80px] animate-blob" style="animation-delay: -14s;"></div>
    </div>

    <!-- Bezier curve decorative SVG -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden parallax-medium opacity-20">
      <svg class="absolute top-20 right-10 w-64 h-64 text-accent/30" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M20,100 C20,20 180,20 180,100" stroke-dasharray="5,5" />
        <circle cx="20" cy="100" r="4" fill="currentColor" />
        <circle cx="180" cy="100" r="4" fill="currentColor" />
        <rect x="90" y="15" width="8" height="8" rx="1" fill="currentColor" opacity="0.5" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-accent/20" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.8">
        <path d="M10,80 Q50,10 90,80" stroke-dasharray="3,3" />
        <path d="M20,80 Q50,25 80,80" stroke-dasharray="3,3" opacity="0.5" />
      </svg>
    </div>

    <!-- Sakura petals -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="sakura-petal petal-1"></div>
      <div class="sakura-petal petal-2"></div>
      <div class="sakura-petal petal-3"></div>
      <div class="sakura-petal petal-4"></div>
      <div class="sakura-petal petal-5"></div>
      <div class="sakura-petal petal-6"></div>
      <div class="sakura-petal petal-7"></div>
    </div>

    <!-- Mouse-follow gradient overlay -->
    <div id="heroGlow" class="absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-1000">
      <div class="absolute w-[500px] h-[500px] rounded-full bg-gradient-radial from-accent/10 via-transparent to-transparent blur-2xl"
           style="transform: translate(-50%, -50%);" id="heroGlowInner"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full glass border border-accent/20 shadow-sm mb-8">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          <span class="text-sm text-text-secondary font-medium">Motion Designer & Creative Developer</span>
        </div>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 reveal stagger-1">
        Hi, I'm <span class="bg-gradient-to-r from-accent via-accent-dark to-accent bg-clip-text text-transparent">Kiyo</span>
      </h1>

      <p class="text-xl md:text-2xl text-text-secondary mb-4 reveal stagger-2 font-light tracking-wide">
        Motion · Design · Animation
      </p>

      <p class="text-text-secondary max-w-xl mx-auto mb-10 reveal stagger-3 leading-relaxed">
        用动态视觉讲述故事，在像素与关键帧之间探索创意。<br class="hidden md:block" />
        专注于动效设计、UI/UX 与数字艺术创作。
      </p>

      <div class="flex items-center justify-center gap-4 reveal stagger-4">
        <a href="/kiyo/blog/" class="group relative px-7 py-3.5 bg-gradient-to-r from-accent to-accent-dark text-white rounded-xl font-medium transition-all duration-300 hover:shadow-xl hover:shadow-accent/25 hover:-translate-y-1">
          <span class="relative z-10">阅读博客</span>
        </a>
        <a href="/kiyo/about/" class="px-7 py-3.5 glass border border-accent/20 rounded-xl font-medium hover:bg-white/90 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40">
          了解更多
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 reveal stagger-5">
        <div class="flex flex-col items-center gap-2 text-text-secondary/50">
          <span class="text-xs tracking-widest uppercase">Scroll</span>
          <div class="w-5 h-8 rounded-full border-2 border-current flex items-start justify-center p-1">
            <div class="w-1 h-2 rounded-full bg-current animate-bounce"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="wave-divider mt-[-2px]">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <defs>
        <linearGradient id="wave1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#fce4ec;stop-opacity:0.4" />
          <stop offset="100%" style="stop-color:#fff1f2;stop-opacity:0.6" />
        </linearGradient>
      </defs>
      <path d="M0,40 C480,80 960,0 1440,50 L1440,100 L0,100 Z" fill="url(#wave1)" />
    </svg>
  </div>

  <!-- Recent Posts Section -->
  {posts.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="flex items-center justify-between mb-10 reveal">
        <h2 class="text-2xl font-bold flex items-center gap-3">
          <span class="w-8 h-1 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>
          最新文章
        </h2>
        <a href="/kiyo/blog/" class="text-accent hover:text-accent-dark text-sm font-medium transition-colors flex items-center gap-1 group">
          查看全部
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, index) => (
          <a
            href={`/kiyo/blog/${post.id}/`}
            class:list={[
              'group tilt-card glow-card relative block p-6 glass rounded-2xl border border-accent/10 transition-all duration-500 hover:border-accent/30 hover:shadow-2xl hover:shadow-accent/10 hover:-translate-y-2 reveal stagger-' + (index + 1),
            ]}
          >
            <div class="relative z-10">
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-gradient-to-r from-accent-light to-pink-50 text-accent-dark font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              <h3 class="font-semibold text-lg mb-2 group-hover:text-accent transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-text-secondary text-sm line-clamp-2 mb-4">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between">
                <time class="text-xs text-text-secondary/70">
                  {formatDate(post.data.publishDate)}
                </time>
                <svg class="w-4 h-4 text-accent/50 group-hover:text-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Design Tools Decoration Section -->
  <section class="relative py-16 overflow-hidden">
    <div class="max-w-4xl mx-auto px-6">
      <div class="reveal text-center mb-12">
        <h2 class="text-2xl font-bold mb-3">Creative Toolkit</h2>
        <p class="text-text-secondary text-sm">用工具将创意变为现实</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6 reveal stagger-1">
        {['After Effects', 'Blender', 'Figma', 'Cinema 4D', 'Premiere Pro', 'Photoshop'].map((tool, i) => (
          <div class:list={['tilt-card glass px-6 py-3 rounded-xl border border-accent/10 text-sm font-medium text-text-secondary hover:text-accent hover:border-accent/30 transition-all duration-300 stagger-' + (i + 1)]}>
            {tool}
          </div>
        ))}
      </div>
    </div>
    <!-- Background decorative keyframe timeline -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
  </section>
</BaseLayout>

<style>
  /* Sakura petal animation - improved */
  .sakura-petal {
    position: absolute;
    background: linear-gradient(135deg, #e8a4b8, #f5c6d0);
    opacity: 0;
    border-radius: 50% 0 50% 0;
    animation: petalFall linear infinite;
    filter: blur(0.5px);
  }

  .petal-1 { left: 5%; width: 14px; height: 14px; animation-duration: 14s; animation-delay: 0s; }
  .petal-2 { left: 20%; width: 10px; height: 10px; animation-duration: 18s; animation-delay: 2s; }
  .petal-3 { left: 35%; width: 16px; height: 16px; animation-duration: 12s; animation-delay: 5s; }
  .petal-4 { left: 55%; width: 8px; height: 8px; animation-duration: 16s; animation-delay: 1s; }
  .petal-5 { left: 70%; width: 12px; height: 12px; animation-duration: 13s; animation-delay: 3s; }
  .petal-6 { left: 82%; width: 11px; height: 11px; animation-duration: 17s; animation-delay: 6s; }
  .petal-7 { left: 92%; width: 9px; height: 9px; animation-duration: 15s; animation-delay: 4s; }

  @keyframes petalFall {
    0% {
      transform: translateY(-5vh) translateX(0) rotate(0deg) scale(1);
      opacity: 0;
    }
    8% { opacity: 0.5; }
    25% { transform: translateY(25vh) translateX(60px) rotate(180deg) scale(0.9); }
    50% { transform: translateY(50vh) translateX(-30px) rotate(360deg) scale(0.85); opacity: 0.4; }
    75% { transform: translateY(75vh) translateX(40px) rotate(540deg) scale(0.7); }
    92% { opacity: 0.1; }
    100% {
      transform: translateY(105vh) translateX(20px) rotate(720deg) scale(0.5);
      opacity: 0;
    }
  }

  /* Radial gradient utility */
  .bg-gradient-radial {
    background: radial-gradient(circle, var(--tw-gradient-stops));
  }
</style>

<script>
  // Hero mouse-follow gradient
  const heroSection = document.querySelector('section')!;
  const heroGlow = document.getElementById('heroGlow')!;
  const heroGlowInner = document.getElementById('heroGlowInner')!;

  heroSection.addEventListener('mouseenter', () => {
    heroGlow.style.opacity = '1';
  });
  heroSection.addEventListener('mouseleave', () => {
    heroGlow.style.opacity = '0';
  });
  heroSection.addEventListener('mousemove', (e) => {
    const rect = heroSection.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    heroGlowInner.style.left = `${x}px`;
    heroGlowInner.style.top = `${y}px`;
  });
</script>
