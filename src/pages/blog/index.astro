---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
};

// Group posts by year
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.publishDate.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Blog" description="Kiyo's blog posts - Design, Animation & Creative Development">
  <!-- Background decoration -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
    <div class="absolute top-40 left-20 w-80 h-80 bg-gradient-to-br from-pink-100/20 to-transparent rounded-full blur-[100px]"></div>
    <div class="absolute bottom-20 right-20 w-72 h-72 bg-gradient-to-tl from-accent/8 to-transparent rounded-full blur-[100px]"></div>
  </div>

  <section class="max-w-4xl mx-auto px-6 py-16 pt-24">
    <!-- Page Header -->
    <div class="mb-14 reveal">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="bg-gradient-to-r from-accent to-accent-dark bg-clip-text text-transparent">Blog</span>
      </h1>
      <p class="text-text-secondary text-lg">
        设计思考、动画技巧、创意编程 —— 记录创作与成长的每一步
      </p>
      <!-- Decorative line -->
      <div class="mt-6 w-20 h-1 rounded-full bg-gradient-to-r from-accent to-accent-dark"></div>
    </div>

    <!-- Posts by Year -->
    {years.length > 0 ? (
      <div class="space-y-14">
        {years.map((year, yi) => (
          <div class:list={['reveal stagger-' + Math.min(yi + 1, 5)]}>
            <h2 class="text-2xl font-bold mb-6 text-accent flex items-center gap-3">
              <span class="font-mono bg-gradient-to-r from-accent-light to-pink-50 px-3 py-1 rounded-lg text-accent-dark border border-accent/10">{year}</span>
              <span class="flex-1 h-px bg-gradient-to-r from-accent/20 to-transparent"></span>
            </h2>
            <div class="space-y-4">
              {postsByYear[Number(year)].map((post, pi) => (
                <a
                  href={`/kiyo/blog/${post.id}/`}
                  class:list={[
                    'group glow-card tilt-card block p-5 glass rounded-2xl border border-accent/10 hover:border-accent/30 transition-all duration-500 hover:shadow-xl hover:shadow-accent/8 hover:-translate-y-1 reveal stagger-' + Math.min(pi + 1, 8),
                  ]}
                >
                  <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-3 md:gap-6">
                    <time class="text-sm text-text-secondary/70 whitespace-nowrap font-mono">
                      {formatDate(post.data.publishDate)}
                    </time>
                    <div class="flex-1">
                      <h3 class="font-semibold text-lg group-hover:text-accent transition-colors duration-300">
                        {post.data.title}
                      </h3>
                      <p class="text-text-secondary text-sm mt-1 line-clamp-1">
                        {post.data.description}
                      </p>
                    </div>
                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.slice(0, 3).map(tag => (
                          <span class="text-xs px-2.5 py-1 rounded-full bg-gradient-to-r from-accent-light/60 to-pink-50 text-accent-dark font-medium border border-accent/5">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <svg class="w-5 h-5 text-accent/30 group-hover:text-accent group-hover:translate-x-1 transition-all duration-300 flex-shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 reveal">
        <div class="text-6xl mb-4">✨</div>
        <p class="text-text-secondary text-lg">还没有文章，敬请期待...</p>
      </div>
    )}
  </section>
</BaseLayout>
