---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = [
  { name: 'Motion Design', items: ['After Effects', 'Lottie', 'CSS Animation', 'GSAP', 'Rive'] },
  { name: 'UI/UX Design', items: ['Figma', 'Framer', 'Prototyping', 'Design System', 'User Research'] },
  { name: '3D & Visual', items: ['Blender', 'Cinema 4D', 'Photoshop', 'Illustrator', 'Premiere Pro'] },
  { name: 'Development', items: ['React', 'TypeScript', 'Astro', 'Tailwind CSS', 'Three.js'] },
];

const timeline = [
  { year: '2025', event: '深入 Motion Design 领域，探索动态叙事与交互体验设计' },
  { year: '2024', event: '构建个人创意品牌，分享设计与动画教程' },
  { year: '2023', event: '学习 3D 建模与动态视觉，掌握 Blender 与 C4D' },
  { year: '2022', event: '进入 UI/UX 设计领域，研究用户体验与交互设计' },
  { year: '2021', event: '开启创意编程之旅，融合代码与视觉艺术' },
];
---

<BaseLayout title="About" description="About Kiyo - Motion Designer & Creative Developer">
  <!-- Background decoration -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
    <div class="absolute top-20 right-20 w-96 h-96 bg-gradient-to-bl from-pink-100/30 to-transparent rounded-full blur-[120px]"></div>
    <div class="absolute bottom-40 left-10 w-72 h-72 bg-gradient-to-tr from-accent/10 to-transparent rounded-full blur-[100px]"></div>
  </div>

  <section class="max-w-4xl mx-auto px-6 py-20 pt-24">
    <!-- Header -->
    <div class="mb-16 reveal">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        About <span class="bg-gradient-to-r from-accent to-accent-dark bg-clip-text text-transparent">Me</span>
      </h1>
      <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
        你好！我是 Kiyo，一名热爱动态设计与创意表达的 Motion Designer。
        我相信好的设计不仅在于视觉美感，更在于通过动画与交互讲述打动人心的故事。
      </p>
    </div>

    <!-- Profile Section -->
    <div class="grid md:grid-cols-3 gap-12 mb-20">
      <div class="md:col-span-1 reveal-left">
        <div class="sticky top-24">
          <div class="relative w-48 h-48 mx-auto md:mx-0 rounded-2xl overflow-hidden group">
            <!-- Gradient border effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-accent via-accent-dark to-pink-300 rounded-2xl p-[2px]">
              <div class="w-full h-full rounded-2xl bg-white flex items-center justify-center overflow-hidden">
                <svg class="w-24 h-24 text-accent group-hover:scale-110 transition-transform duration-700" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C12 2 9.5 6 9.5 9C9.5 10.5 10.5 12 12 12C13.5 12 14.5 10.5 14.5 9C14.5 6 12 2 12 2Z"/>
                  <path d="M12 22C12 22 14.5 18 14.5 15C14.5 13.5 13.5 12 12 12C10.5 12 9.5 13.5 9.5 15C9.5 18 12 22 12 22Z"/>
                  <path d="M2 12C2 12 6 9.5 9 9.5C10.5 9.5 12 10.5 12 12C12 13.5 10.5 14.5 9 14.5C6 14.5 2 12 2 12Z"/>
                  <path d="M22 12C22 12 18 14.5 15 14.5C13.5 14.5 12 13.5 12 12C12 10.5 13.5 9.5 15 9.5C18 9.5 22 12 22 12Z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="mt-6 text-center md:text-left">
            <h2 class="text-xl font-bold">Kiyo</h2>
            <p class="text-accent text-sm font-medium">Motion Designer & Creative Developer</p>
            <div class="flex justify-center md:justify-start gap-3 mt-4">
              <a href="https://github.com/tetsuyaZ" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full glass border border-accent/10 text-text-secondary hover:text-accent hover:border-accent/30 transition-all duration-300 hover:-translate-y-0.5">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href="mailto:hello@kiyo.dev" class="w-9 h-9 flex items-center justify-center rounded-full glass border border-accent/10 text-text-secondary hover:text-accent hover:border-accent/30 transition-all duration-300 hover:-translate-y-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="md:col-span-2 space-y-12">
        <!-- Skills with Elastic Tags -->
        <div class="reveal-right">
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
            <span class="w-8 h-1 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>
            技能 & 工具
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {skills.map((category, ci) => (
              <div class:list={['tilt-card glass p-5 rounded-2xl border border-accent/10 hover:border-accent/25 transition-all duration-300 reveal stagger-' + (ci + 1)]}>
                <h3 class="font-semibold text-accent mb-3 text-sm uppercase tracking-wider">{category.name}</h3>
                <div class="flex flex-wrap gap-2">
                  {category.items.map((item, ii) => (
                    <span class:list={[
                      'skill-tag text-sm px-3 py-1.5 rounded-full bg-gradient-to-r from-accent-light/80 to-pink-50 text-accent-dark font-medium border border-accent/10 hover:border-accent/30 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300',
                      'stagger-' + Math.min(ii + 1, 8),
                    ]}>
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Timeline with Draw Animation -->
        <div class="reveal-right stagger-3">
          <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="w-8 h-1 rounded-full bg-gradient-to-r from-accent to-accent-dark"></span>
            成长轨迹
          </h2>
          <div class="relative">
            <!-- Animated timeline line -->
            <div class="absolute left-[27px] top-0 bottom-0 w-[2px]">
              <div class="timeline-line w-full h-full relative">
                <div class="absolute inset-0 bg-gradient-to-b from-accent via-accent-dark to-pink-200"></div>
              </div>
            </div>

            <div class="space-y-6">
              {timeline.map((item, index) => (
                <div class:list={['flex gap-5 items-start reveal stagger-' + (index + 1)]}>
                  <div class="relative z-10 mt-1 flex-shrink-0">
                    <div class="w-4 h-4 rounded-full bg-gradient-to-br from-accent to-accent-dark border-2 border-white shadow-md shadow-accent/20"></div>
                  </div>
                  <div class="glass rounded-xl p-4 border border-accent/10 flex-1 hover:border-accent/25 transition-all duration-300 group">
                    <span class="text-sm font-mono text-accent font-bold">{item.year}</span>
                    <p class="text-text-secondary mt-1 text-sm leading-relaxed group-hover:text-text transition-colors">{item.event}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bezier Curve Decoration -->
    <div class="relative my-16 reveal">
      <svg class="w-full h-20 text-accent/15" viewBox="0 0 800 80" fill="none" stroke="currentColor" stroke-width="1" preserveAspectRatio="none">
        <path d="M0,40 C200,10 400,70 600,30 C700,15 750,50 800,40" stroke-dasharray="8,4" />
        <circle cx="0" cy="40" r="3" fill="currentColor" />
        <circle cx="200" cy="10" r="2" fill="currentColor" opacity="0.5" />
        <circle cx="400" cy="70" r="2" fill="currentColor" opacity="0.5" />
        <circle cx="600" cy="30" r="2" fill="currentColor" opacity="0.5" />
        <circle cx="800" cy="40" r="3" fill="currentColor" />
      </svg>
    </div>

    <!-- Contact CTA -->
    <div class="relative reveal">
      <div class="glass rounded-3xl p-10 border border-accent/15 text-center overflow-hidden">
        <!-- Background gradient blobs -->
        <div class="absolute top-0 left-0 w-40 h-40 bg-accent/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-40 h-40 bg-pink-100/20 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

        <div class="relative z-10">
          <h2 class="text-2xl font-bold mb-3">保持联系</h2>
          <p class="text-text-secondary mb-6 max-w-md mx-auto">
            如果你对动效设计、创意项目合作感兴趣，或者只是想交流设计心得，欢迎联系我！
          </p>
          <a href="mailto:hello@kiyo.dev" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-accent to-accent-dark text-white rounded-xl font-medium hover:shadow-xl hover:shadow-accent/25 transition-all duration-300 hover:-translate-y-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            发送邮件
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Skill tag elastic hover */
  .skill-tag {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease;
  }

  .skill-tag:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 4px 15px rgba(232, 164, 184, 0.2);
  }
</style>
